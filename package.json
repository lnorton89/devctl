{
  "name": "devctl",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names server,client \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --port 5273",
    "dev:server": "tsx watch src/server/index.ts --port 4002",
    "startup:install": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/install-windows-startup.ps1",
    "startup:uninstall": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/uninstall-windows-startup.ps1",
    "startup:status": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/windows-startup-status.ps1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@fontsource/spline-sans-mono": "^5.2.8",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.1",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
